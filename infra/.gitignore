# Local state (only exists before bootstrap remote state is set up)
*.tfstate
*.tfstate.backup
.terraform/
.terraform.lock.hcl

# Secret variable files — never commit
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash logs
crash.log
crash.*.log
